{
  "name": "artidor",
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "packages/*",
    "rust/wasm/pkg"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build rust/wasm --target bundler --out-dir pkg && rm -f rust/wasm/pkg/.gitignore",
    "build:web": "turbo run build --filter=@artidor/web",
    "clean:web": "bun x rimraf apps/web/.next apps/web/.content-collections/cache node_modules/.cache",
    "deploy:web": "turbo run deploy --filter=@artidor/web",
    "dev:wasm": "cargo watch -w rust/crates -w rust/wasm/src -s 'wasm-pack build rust/wasm --target bundler --out-dir pkg'",
    "dev:web": "turbo run dev --filter=@artidor/web",
    "dev:web:clean": "bun run clean:web && bun run dev:web",
    "format:web": "biome format apps/web/src/services/renderer --write --max-diagnostics=1000",
    "generate:fonts": "npx tsx apps/web/scripts/generate-font-sprites.ts",
    "lint:web": "biome lint apps/web/src --max-diagnostics=1000",
    "lint:web:fix": "biome lint apps/web/src --write --unsafe --max-diagnostics=1000",
    "preview:web": "turbo run preview --filter=@artidor/web",
    "harness:whats-new": "bun scripts/whats-new-check.mjs",
    "publish:wasm": "bun run build:wasm && npm publish rust/wasm/pkg --access public",
    "test": "bun test apps/web/src",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.8",
    "@protobufjs/utf8": "^1.1.1",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.6.20",
    "brace-expansion": "^5.0.6",
    "defu": "^6.1.7",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.1",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.9.3",
    "form-data": "^4.0.6",
    "js-yaml": "^5.1.0",
    "kysely": "^0.29.2",
    "mdast-util-to-hast": "^13.2.1",
    "next": "^16.2.9",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "protobufjs": "^8.6.4",
    "qs": "^6.15.2",
    "serialize-javascript": "^7.0.6",
    "tar": "^7.5.16",
    "undici": "^8.5.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "playwright": "^1.61.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.2"
  },
  "resolutions": {
    "@protobufjs/utf8": "^1.1.1",
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.1",
    "fast-xml-builder": "^1.2.0",
    "fast-xml-parser": "^5.9.3",
    "form-data": "^4.0.6",
    "js-yaml": "^5.1.0",
    "mdast-util-to-hast": "^13.2.1",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.15",
    "protobufjs": "^8.6.4",
    "qs": "^6.15.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serialize-javascript": "^7.0.6",
    "tar": "^7.5.16",
    "undici": "^8.5.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
