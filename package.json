{
  "name": "artidor",
  "packageManager": "bun@1.2.18",
  "workspaces": [
    "apps/*",
    "packages/*",
    "rust/wasm/pkg"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build rust/wasm --target bundler --out-dir pkg && rm -f rust/wasm/pkg/.gitignore",
    "build:web": "turbo run build --filter=@artidor/web",
    "deploy:web": "turbo run deploy --filter=@artidor/web",
    "dev:wasm": "cargo watch -w rust/crates -w rust/wasm/src -s 'wasm-pack build rust/wasm --target bundler --out-dir pkg'",
    "dev:web": "turbo run dev --filter=@artidor/web",
    "format:web": "biome format apps/web/src/services/renderer --write --max-diagnostics=1000",
    "generate:fonts": "npx tsx apps/web/scripts/generate-font-sprites.ts",
    "lint:web": "biome lint apps/web/src --max-diagnostics=1000",
    "lint:web:fix": "biome lint apps/web/src --write --unsafe --max-diagnostics=1000",
    "preview:web": "turbo run preview --filter=@artidor/web",
    "publish:wasm": "bun run build:wasm && npm publish rust/wasm/pkg --access public",
    "test": "bun test apps/web/src",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "better-auth": "^1.4.15",
    "next": "^16.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "playwright": "^1.61.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.2"
  },
  "resolutions": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide"
  ]
}
